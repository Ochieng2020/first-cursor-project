# Backend
ENVIRONMENT=development
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database
# For local dev, docker-compose will provide postgres; fallback uses SQLite
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/echo

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Encryption (base64, 16/24/32 bytes)
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
ECHO_ENCRYPTION_KEY=

# LLM
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_PERSIST_DIR=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
